<script>
const TOTAL=13;
let cur=0,tr=false;

const nd=document.getElementById('ndots');
for(let i=0;i<TOTAL;i++){
  const d=document.createElement('div');
  d.className='dot'+(i===0?' active':'');
  d.onclick=()=>goToSlide(i);
  nd.appendChild(d);
}

function updateUI(){
  document.getElementById('prog').style.width=((cur+1)/TOTAL*100)+'%';
  document.getElementById('nc').textContent=(cur+1)+' / '+TOTAL;
  document.querySelectorAll('.dot').forEach((d,i)=>d.classList.toggle('active',i===cur));
}

function goToSlide(n){
  if(tr||n===cur)return;
  tr=true;
  const p=document.getElementById('slide-'+cur);
  const nx=document.getElementById('slide-'+n);
  p.classList.add('exit');p.classList.remove('active');
  setTimeout(()=>{
    p.classList.remove('exit');
    nx.classList.add('active');
    cur=n;updateUI();
    setTimeout(()=>{tr=false;},550);
  },260);
}

function nextSlide(){goToSlide(Math.min(cur+1,TOTAL-1));}
function prevSlide(){goToSlide(Math.max(cur-1,0));}

document.addEventListener('keydown',e=>{
  if(e.key==='ArrowRight'||e.key==='ArrowDown')nextSlide();
  if(e.key==='ArrowLeft'||e.key==='ArrowUp')prevSlide();
});

let tx=0;
document.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;});
document.addEventListener('touchend',e=>{
  const dx=tx-e.changedTouches[0].clientX;
  if(Math.abs(dx)>50)dx>0?nextSlide():prevSlide();
});

function switchModule(n){
  document.querySelectorAll('.mtab').forEach((t,i)=>t.classList.toggle('active',i===n));
  document.querySelectorAll('.mdet').forEach((d,i)=>{
    d.style.display=i===n?'block':'none';
    if(i===n)d.classList.add('active');else d.classList.remove('active');
  });
}

function switchTier(n){
  document.querySelectorAll('.tbtn').forEach((b,i)=>b.classList.toggle('active',i===n));
  document.querySelectorAll('.tpanel').forEach((p,i)=>p.classList.toggle('active',i===n));
}

updateUI();
</script>
