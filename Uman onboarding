<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Uman.ai — Employee Onboarding</title>
<style>
:root {
  --o: #E8714A; --ol: #F5A678; --od: #C45A32;
  --dk: #0A0A0A; --dk2: #141414; --dk3: #1C1C1C;
  --wh: #FFFFFF; --mid: #777777; --lt: #AAAAAA;
  --bl: #4A6CF7; --gr: #059669; --pu: #7B5CF0; --ye: #F59E0B;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;font-family:'Trebuchet MS','Segoe UI',Arial,sans-serif;background:var(--dk);overflow:hidden;color:var(--wh)}

/* PROGRESS */
.prog{position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,var(--o),var(--ol));transition:width .5s cubic-bezier(.4,0,.2,1);z-index:100}

/* NAV */
.nav{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);z-index:100;display:flex;align-items:center;gap:12px;background:rgba(255,255,255,.05);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.08);border-radius:100px;padding:7px 15px}
.nb{width:32px;height:32px;border-radius:50%;border:none;background:rgba(255,255,255,.07);color:white;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s}
.nb:hover{background:var(--o)}
.ndots{display:flex;gap:4px;align-items:center}
.dot{width:4px;height:4px;border-radius:50%;background:rgba(255,255,255,.2);cursor:pointer;transition:all .3s}
.dot.active{background:var(--o);width:14px;border-radius:2px}
.nc{font-size:10px;color:rgba(255,255,255,.25);min-width:32px;text-align:center}
.kh{position:fixed;top:14px;right:18px;font-size:9px;color:rgba(255,255,255,.15);z-index:100}

/* SLIDES */
.sw{width:100%;height:100vh;position:relative;overflow:hidden}
.slide{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .5s cubic-bezier(.4,0,.2,1),transform .5s cubic-bezier(.4,0,.2,1);transform:translateY(20px)}
.slide.active{opacity:1;pointer-events:all;transform:translateY(0)}
.slide.exit{opacity:0;transform:translateY(-20px)}

/* ORBS */
.orb{position:absolute;border-radius:50%;pointer-events:none}
@keyframes fl{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-14px) scale(1.03)}}
@keyframes sp{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes fu{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes pi{from{opacity:0;transform:scale(.92)}to{opacity:1;transform:scale(1)}}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(232,113,74,.35)}50%{box-shadow:0 0 0 10px rgba(232,113,74,0)}}

/* COMMON */
.in{width:100%;max-width:1100px;padding:44px 64px;position:relative;z-index:2}
.lbl{font-size:8px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--o);margin-bottom:8px}
.h1{font-size:clamp(28px,4vw,48px);font-weight:800;letter-spacing:-2px;line-height:1;margin-bottom:24px;color:var(--wh)}
.h1 span{color:var(--o)}
.card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:22px 20px;transition:border-color .3s,transform .2s;cursor:default}
.card:hover{border-color:rgba(232,113,74,.3);transform:translateY(-2px)}

/* SECTION PILLS */
.section-nav{display:flex;gap:8px;margin-bottom:28px;flex-wrap:wrap}
.snav-btn{padding:7px 16px;border-radius:100px;border:1px solid rgba(255,255,255,.1);background:transparent;color:rgba(255,255,255,.35);font-size:11px;font-weight:700;cursor:pointer;transition:all .25s;font-family:'Trebuchet MS','Segoe UI',Arial,sans-serif}
.snav-btn:hover{border-color:rgba(255,255,255,.25);color:white}
.snav-btn.active{background:var(--o);border-color:var(--o);color:white}

/* TABS */
.tabs{display:flex;margin-bottom:22px;border-radius:10px;overflow:hidden;border:1px solid rgba(255,255,255,.07);width:fit-content}
.tab{padding:9px 22px;font-weight:700;font-size:11px;cursor:pointer;background:transparent;color:rgba(255,255,255,.3);border:none;transition:all .3s;font-family:'Trebuchet MS','Segoe UI',Arial,sans-serif}
.tab.active{background:var(--o);color:white}
.tab-panel{display:none}
.tab-panel.active{display:block;animation:fu .3s ease}

/* ── COVER ── */
.cover-wrap{position:relative;z-index:2;padding:0 64px;max-width:1100px;width:100%}
.logo-row{display:flex;align-items:center;gap:10px;margin-bottom:44px}
.logo-c{width:38px;height:38px;border-radius:50%;background:var(--wh);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:15px;color:var(--dk)}
.logo-n{font-size:16px;font-weight:600;color:white}
.ctag{display:inline-block;background:rgba(232,113,74,.1);border:1px solid rgba(232,113,74,.25);color:var(--ol);font-size:8px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;padding:4px 12px;border-radius:100px;margin-bottom:16px}
.ctitle{font-size:clamp(44px,7vw,88px);font-weight:800;letter-spacing:-4px;line-height:.98;margin-bottom:18px;color:white}
.ctitle span{color:var(--o)}
.csub{font-size:14px;color:rgba(255,255,255,.38);font-weight:300;margin-bottom:36px;max-width:440px;line-height:1.6}
.cpill{display:inline-flex;align-items:center;gap:9px;background:white;color:var(--dk);font-weight:700;font-size:12px;padding:12px 22px;border-radius:100px;cursor:pointer;border:none;transition:transform .2s,box-shadow .2s;font-family:'Trebuchet MS','Segoe UI',Arial,sans-serif}
.cpill:hover{transform:translateY(-2px);box-shadow:0 16px 32px rgba(0,0,0,.3)}
.cpill .arr{width:22px;height:22px;border-radius:50%;background:var(--o);display:flex;align-items:center;justify-content:center;font-size:11px}

/* ── WHO WE ARE ── */
.stats3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:18px}
.stat-c{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 18px;transition:all .3s;cursor:default}
.stat-c:hover{border-color:rgba(232,113,74,.35);background:rgba(232,113,74,.04)}
.stat-n{font-size:32px;font-weight:800;color:var(--o);letter-spacing:-2px;line-height:1;margin-bottom:5px}
.stat-l{font-size:11px;color:var(--mid);line-height:1.4}
.tbar{background:linear-gradient(135deg,var(--o),var(--od));border-radius:12px;padding:18px 22px;margin-bottom:16px}
.tbar p{font-size:17px;font-weight:700;color:white;letter-spacing:-.3px}
.tbar span{font-size:11px;color:rgba(255,255,255,.6);display:block;margin-top:3px}
.ibox{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:16px 20px;font-size:12px;color:rgba(255,255,255,.5);line-height:1.7}
.ibox strong{color:rgba(255,255,255,.8);font-weight:600}

/* ── TEAM ── */
.tgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:20px}
.tcard{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:18px 14px;display:flex;flex-direction:column;align-items:center;gap:10px;cursor:pointer;transition:all .3s;position:relative;overflow:visible;text-align:center}
.tcard:hover{transform:translateY(-3px);border-color:rgba(255,255,255,.18)}
.av{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:17px;color:white}
.tn{font-size:13px;font-weight:700;color:white}
.tr{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin:2px 0}
.td{font-size:10px;color:rgba(255,255,255,.3)}
/* Hover popup */
.hpop{position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%) scale(.93);background:#1A1A1A;border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:14px 16px;width:220px;opacity:0;pointer-events:none;transition:all .22s cubic-bezier(.4,0,.2,1);z-index:200;box-shadow:0 16px 36px rgba(0,0,0,.5);text-align:left}
.tcard:hover .hpop{opacity:1;pointer-events:all;transform:translateX(-50%) scale(1)}
.hpop h4{font-size:12px;font-weight:700;color:white;margin-bottom:5px}
.hpop p{font-size:10px;color:var(--mid);line-height:1.5}
.hpop .ht{margin-top:8px;padding:6px 8px;background:rgba(232,113,74,.1);border:1px solid rgba(232,113,74,.2);border-radius:7px;font-size:9px;color:var(--ol)}

/* ── PLATFORM / MODULES ── */
.prod-layout{display:grid;grid-template-columns:1fr 1.5fr;gap:26px;align-items:start;width:100%;max-width:1100px;padding:44px 64px}
.mtabs{display:flex;flex-direction:column;gap:8px}
.mtab{display:flex;align-items:center;gap:12px;padding:14px 16px;border-radius:12px;cursor:pointer;background:rgba(255,255,255,.04);border:1.5px solid rgba(255,255,255,.07);transition:all .3s}
.mtab:hover{border-color:var(--o)}
.mtab.active{background:var(--o);border-color:var(--o)}
.mnum{width:30px;height:30px;min-width:30px;border-radius:50%;background:rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:11px;color:white}
.mname{font-size:13px;font-weight:700;color:white}
.mdet{display:none}
.mdet.active{display:block;animation:fu .3s ease}
.mcard{border-radius:20px;padding:30px 26px;position:relative;overflow:hidden}
.mcard::before{content:'';position:absolute;width:180px;height:180px;border-radius:50%;top:-45px;right:-45px;opacity:.1}
.mc0{background:rgba(74,108,247,.08);border:1px solid rgba(74,108,247,.2)}
.mc0::before{background:var(--bl)}
.mc1{background:rgba(232,113,74,.08);border:1px solid rgba(232,113,74,.2)}
.mc1::before{background:var(--o)}
.mc2{background:rgba(5,150,105,.08);border:1px solid rgba(5,150,105,.2)}
.mc2::before{background:var(--gr)}
.mct{font-size:22px;font-weight:800;color:white;letter-spacing:-1px;margin-bottom:4px;position:relative;z-index:1}
.mcs{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:2px;margin-bottom:12px;position:relative;z-index:1}
.mcd{font-size:12px;color:var(--lt);line-height:1.7;margin-bottom:18px;position:relative;z-index:1}
.mcf{display:flex;flex-direction:column;gap:7px;position:relative;z-index:1}
.mcfi{display:flex;align-items:flex-start;gap:8px;font-size:11px;color:rgba(255,255,255,.7)}
.fdot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:3px}
.tools-row{display:flex;flex-direction:column;gap:7px;margin-top:16px;position:relative;z-index:1}
.tool-pill{display:flex;align-items:center;gap:8px;padding:8px 12px;background:rgba(0,0,0,.2);border-radius:8px;font-size:11px;color:rgba(255,255,255,.7)}
.tool-badge{font-size:8px;font-weight:700;padding:2px 7px;border-radius:100px;margin-left:auto}
.int-row{display:flex;gap:7px;flex-wrap:wrap;margin-top:14px;position:relative;z-index:1}
.int-b{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:7px;padding:4px 10px;font-size:10px;color:var(--mid)}

/* ── SPICED ── */
.spiced-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:22px}
.sp-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 18px;transition:all .3s;cursor:default;position:relative;overflow:hidden}
.sp-card:hover{transform:translateY(-2px);border-color:rgba(232,113,74,.25)}
.sp-letter{font-size:48px;font-weight:800;color:rgba(232,113,74,.12);position:absolute;top:-8px;right:12px;line-height:1;letter-spacing:-2px}
.sp-title{font-size:14px;font-weight:700;color:white;margin-bottom:5px;position:relative;z-index:1}
.sp-sub{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--o);margin-bottom:10px;position:relative;z-index:1}
.sp-desc{font-size:11px;color:var(--mid);line-height:1.5;position:relative;z-index:1}
.sp-outcome{margin-top:10px;padding:7px 10px;background:rgba(232,113,74,.08);border:1px solid rgba(232,113,74,.15);border-radius:8px;font-size:10px;color:var(--ol);position:relative;z-index:1}

/* ── ICP ── */
.tier-sel{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap}
.tbtn{padding:8px 20px;border-radius:100px;border:1.5px solid rgba(255,255,255,.1);background:transparent;color:rgba(255,255,255,.4);font-weight:700;font-size:11px;cursor:pointer;transition:all .3s;font-family:'Trebuchet MS','Segoe UI',Arial,sans-serif}
.tbtn:hover{border-color:rgba(255,255,255,.25);color:white}
.tbtn.active{background:var(--o);border-color:var(--o);color:white}
.tbtn.t2.active{background:var(--bl);border-color:var(--bl)}
.tbtn.t3.active{background:var(--gr);border-color:var(--gr)}
.tpanel{display:none}
.tpanel.active{display:grid;grid-template-columns:1fr 1fr;gap:16px;animation:fu .3s ease}
.tm{border-radius:20px;padding:24px 20px;position:relative;overflow:hidden}
.tm::before{content:'';position:absolute;width:140px;height:140px;border-radius:50%;top:-35px;right:-35px;opacity:.1}
.tm0{background:rgba(232,113,74,.08);border:1px solid rgba(232,113,74,.2)}
.tm0::before{background:var(--o)}
.tm1{background:rgba(74,108,247,.08);border:1px solid rgba(74,108,247,.2)}
.tm1::before{background:var(--bl)}
.tm2{background:rgba(5,150,105,.08);border:1px solid rgba(5,150,105,.2)}
.tm2::before{background:var(--gr)}
.tbadge{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:100px;font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:14px;position:relative;z-index:1}
.tacv{font-size:36px;font-weight:800;letter-spacing:-2px;line-height:1;margin-bottom:3px;position:relative;z-index:1}
.tacvl{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,.3);margin-bottom:16px;position:relative;z-index:1}
.tstats{display:flex;flex-direction:column;gap:7px;position:relative;z-index:1}
.tst{display:flex;align-items:center;justify-content:space-between;padding:7px 10px;border-radius:7px;background:rgba(0,0,0,.2)}
.tsk{font-size:9px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:1px}
.tsv{font-size:11px;font-weight:700;color:white}
.twhy{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:20px;padding:20px 18px}
.twhy h4{font-size:13px;font-weight:700;color:white;margin-bottom:12px}
.wi{display:flex;align-items:flex-start;gap:8px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05)}
.wi:last-child{border-bottom:none;padding-bottom:0}
.wd{width:5px;height:5px;border-radius:50%;margin-top:5px;flex-shrink:0}
.wt{font-size:11px;color:rgba(255,255,255,.5);line-height:1.5}
.wt strong{color:rgba(255,255,255,.8);font-weight:600}

/* ── STRATEGY ── */
.strat-layout{display:grid;grid-template-columns:1fr 1.6fr;gap:18px;margin-top:22px}
.bmet{background:linear-gradient(135deg,var(--o),var(--od));border-radius:20px;padding:26px 22px;position:relative;overflow:hidden}
.bmet::before{content:'';position:absolute;width:160px;height:160px;background:rgba(255,255,255,.08);border-radius:50%;top:-45px;right:-45px}
.bnum{font-size:46px;font-weight:800;color:white;letter-spacing:-3px;line-height:1;position:relative;z-index:1}
.blbl{font-size:12px;color:rgba(255,255,255,.7);margin-top:5px;position:relative;z-index:1}
.bgrow{margin-top:14px;padding-top:14px;border-top:1px solid rgba(255,255,255,.2);font-size:11px;color:rgba(255,255,255,.6);position:relative;z-index:1}
.bgrow strong{color:white}
.geo-c{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:20px;padding:20px 20px}
.geo-c h3{font-size:13px;font-weight:700;color:white;margin-bottom:14px}
.geo-row{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.05);transition:transform .2s;cursor:default}
.geo-row:last-child{border-bottom:none}
.geo-row:hover{transform:translateX(3px)}
.gdot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.gn{font-size:12px;font-weight:700;color:white;flex:1}
.gnote{font-size:10px;color:var(--mid)}
.gbadge{font-size:8px;font-weight:700;padding:2px 8px;border-radius:100px;background:var(--o);color:white}
.kpi3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:14px}
.kpi-c{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:13px 15px;display:flex;gap:10px;align-items:center}
.kpi-n{font-size:24px;font-weight:800;color:var(--o);letter-spacing:-1px}
.kpi-l{font-size:10px;color:var(--mid)}

/* ── TOOLS OPS ── */
.tools-ops-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:20px}
.toc{background:rgba(255,255,255,.04);border:1.5px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 18px;display:flex;gap:14px;transition:all .3s;cursor:default}
.toc:hover{border-color:var(--o);transform:translateY(-2px)}
.tic{width:44px;height:44px;min-width:44px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:12px;color:white}
.toc h4{font-size:13px;font-weight:700;color:white;margin-bottom:3px}
.ttag{display:inline-block;font-size:8px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:2px 8px;border-radius:100px;margin-bottom:6px}
.treq{background:rgba(232,113,74,.15);color:var(--ol)}
.trec{background:rgba(123,92,240,.15);color:#A78BFA}
.tdd{font-size:11px;color:var(--mid);line-height:1.5}

/* ── WAY OF WORKING ── */
.wow-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:16px;margin-top:20px}
.mcol{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 18px}
.mcol h3{font-size:12px;font-weight:700;color:white;margin-bottom:13px}
.mrow{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.05);transition:transform .2s;cursor:default}
.mrow:last-child{border-bottom:none}
.mrow:hover{transform:translateX(3px)}
.fpill{font-size:7px;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:3px 7px;border-radius:100px;white-space:nowrap}
.minfo h5{font-size:11px;font-weight:700;color:white}
.minfo p{font-size:9px;color:var(--mid);margin-top:1px}
.rules-col{display:flex;flex-direction:column;gap:6px}
.rpill{background:rgba(255,255,255,.04);border-radius:10px;padding:11px 13px;display:flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.06);transition:all .22s;cursor:default}
.rpill:hover{border-color:rgba(232,113,74,.28);transform:translateX(3px)}
.rbar{width:3px;height:22px;border-radius:2px;flex-shrink:0}
.rtext{font-size:11px;color:rgba(255,255,255,.6);line-height:1.4}
.rtext strong{color:white;font-weight:700}

/* ── OBJECTIONS ── */
.obj-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:22px}
.obj-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 18px;transition:all .3s;cursor:default}
.obj-card:hover{border-color:rgba(232,113,74,.25);transform:translateY(-2px)}
.obj-q{font-size:13px;font-weight:700;color:var(--o);margin-bottom:10px;display:flex;align-items:flex-start;gap:8px}
.obj-q::before{content:'"';font-size:20px;color:rgba(232,113,74,.4);line-height:1;flex-shrink:0}
.obj-a{font-size:11px;color:rgba(255,255,255,.6);line-height:1.6}
.obj-a strong{color:rgba(255,255,255,.85);font-weight:600}

/* ── WHY IT MATTERS ── */
.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:18px}
.why-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 18px;transition:all .3s;cursor:default}
.why-card:hover{border-color:rgba(232,113,74,.25);transform:translateY(-2px)}
.why-stat{font-size:32px;font-weight:800;color:var(--o);letter-spacing:-2px;line-height:1;margin-bottom:6px}
.why-lbl{font-size:12px;font-weight:700;color:white;margin-bottom:5px}
